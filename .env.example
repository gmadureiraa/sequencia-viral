NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SERPER_API_KEY=
APIFY_API_KEY=
# Fallback scraper de Instagram (opcional). Se nao setar, o app usa so o
# Apify. Docs: https://scrapecreators.com/instagram-api
SCRAPECREATORS_API_KEY=
# ScrapeCreators backup — failover quando a primary bate rate limit (429)
# ou auth falha (401). Ativa automaticamente na helper scrapecreatorsFetch.
SCRAPECREATORS_API_KEY_BACKUP=

# Unsplash — busca de fotos editoriais (stock) como alternativa a geração IA
# quando o image-decider escolhe mode="stock". Freemium (50 req/h demo,
# 5000 req/h production). Docs: https://unsplash.com/documentation
UNSPLASH_ACCESS_KEY=

# Firecrawl — scraping LLM-ready de blogs/artigos. Primario quando sourceType=link.
# Fallback: lib/url-extractor.ts (fetch+regex). Docs: https://docs.firecrawl.dev
FIRECRAWL_API_KEY=

# Perplexity — fact-check live com citations (opt-in via flag useFactCheck
# ou auto-detect em NER dataPoints recentes). Sonar $1/M I/O.
# Docs: https://docs.perplexity.ai
PERPLEXITY_API_KEY=

# Supadata backup — fallback de transcript quando primary (SUPADATA_API_KEY)
# retorna 429 (rate limit) ou 401. Ativa automaticamente na helper supadataFetch.
SUPADATA_API_KEY_BACKUP=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Apenas desenvolvimento local (ex.: curl sem Stripe CLI). NUNCA em produção.
# ALLOW_UNVERIFIED_STRIPE_WEBHOOK=true
# Modelo Gemini para geração de imagens (script generate-landing-assets)
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# ========== Email / Resend ==========
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# ========== Crons ==========
# Segredo para autenticar chamadas manuais aos endpoints /api/cron/*
# (o Vercel Cron autentica automaticamente via header x-vercel-cron).
CRON_SECRET=

# ========== Observability (opcional, fallback silencioso) ==========
# Webhook Discord para alertas do healthcheck. Sem ele, alertas viram console.warn.
DISCORD_WEBHOOK_URL=

# ========== Stripe price IDs (opcional) ==========
# Usados pelo webhook `customer.subscription.updated` para sincronizar o plano
# quando o user faz upgrade/downgrade mid-cycle no portal do Stripe.
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ========== URL público do app ==========
NEXT_PUBLIC_APP_URL=https://sequencia-viral.vercel.app

# ========== Telemetria ==========
# Google Analytics 4 — measurement ID do stream web. Sem ele, GA não carrega.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog — analytics de produto (funil, session recordings, feature flags).
# Host padrão US: https://us.i.posthog.com. EU: https://eu.i.posthog.com.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ========== Stripe (frontend) ==========
# Publishable key — exposta no browser p/ Stripe.js e Elements (checkout).
# Usar chave live em produção (pk_live_...), test em staging (pk_test_...).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ========== Pagamento via wallet (opcional) ==========
# Endereço de carteira cripto para pagamentos diretos on-chain (opt-in).
# OPCIONAL — sem isso, apenas Stripe fica disponível.
NEXT_PUBLIC_PAYMENT_WALLET=0x...

# ========== Facebook / Meta (opcional) ==========
# App ID do Meta para login social e Instagram scraping via OAuth.
# OPCIONAL — sem isso, fluxo OAuth do FB fica desabilitado.
NEXT_PUBLIC_FACEBOOK_APP_ID=1198593178402395

# ========== Testes ==========
# Email de usuário de teste para scripts de smoke test e seeds.
# OPCIONAL — apenas para ambiente local/CI.
TEST_USER_EMAIL=test@example.com

# ========== Supadata (transcrições) ==========
# API primária de transcrição de vídeos YouTube/Instagram.
# Docs: https://supadata.ai
SUPADATA_API_KEY=supa_...

# ========== Rate limit (Upstash Redis) ==========
# Distributed rate limiting compartilhado entre cold starts. Sem essas vars
# o rate-limit cai pra in-memory (per-instance) — OK em dev, frágil em prod.
# Provisionar via Vercel Marketplace → Upstash → KV (REST). Docs:
# https://upstash.com/docs/redis/sdks/ratelimit-ts/overview
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========== Sentry (observabilidade backend) ==========
# DSN do projeto Sentry. Sem ele, init é no-op (zero overhead). Captura
# erros não tratados em /api/generate e demais rotas instrumentadas.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
